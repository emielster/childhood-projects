// How old will you be next year?
/$
How to run:
```bash
cd 2023-fwl/
deno run -A project/run.ts documentation/examples/next_year.fwl
```
$/

task calculate_next_year_age(age) {
    say next_year_age = age + 1;
    println("Next year, you will be ", next_year_age, "years old!");
}

say user = "Larpochka"; // PLEASE MODIFY ME! 
say age = 15; // PLEASE MODIFY ME!

calculate_next_year_age(age);